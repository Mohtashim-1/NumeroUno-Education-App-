 "html": "<style>\n@page {\n\tsize: A4 portrait;\n\tmargin: 8mm 13mm 8mm 13mm;\n}\n\n.print-format {\n\tpadding: 0 !important;\n\tmargin: 0 !important;\n}\n\n.adsd-paper-v2 {\n\tfont-family: Arial, Helvetica, sans-serif;\n\tcolor: #000;\n\twidth: 100%;\n\tmax-width: 185mm;\n\tmargin: 0 auto;\n\tfont-size: 14px;\n\tline-height: 1.15;\n}\n\n/* Header */\n.adsd-paper-v2 .top-area {\n\tposition: relative;\n\theight: 118px;\n\tmargin-top: 5px;\n}\n\n.adsd-paper-v2 .logo-area {\n\tposition: absolute;\n\tleft: 8px;\n\ttop: 0;\n\twidth: 75px;\n\ttext-align: center;\n}\n\n.adsd-paper-v2 .logo-area img {\n\twidth: 55px;\n\theight: auto;\n\tdisplay: block;\n\tmargin: 0 auto;\n}\n\n.adsd-paper-v2 .logo-text {\n\tfont-size: 12px;\n\tfont-weight: 700;\n\tmargin-top: 2px;\n}\n\n.adsd-paper-v2 .title-area {\n\ttext-align: center;\n\tpadding-top: 22px;\n}\n\n.adsd-paper-v2 .main-org {\n\tfont-size: 21px;\n\tfont-weight: 700;\n\tmargin-bottom: 42px;\n}\n\n.adsd-paper-v2 .course-title {\n\tfont-size: 19px;\n\tfont-weight: normal;\n\tmargin-bottom: 2px;\n}\n\n.adsd-paper-v2 .test-title {\n\tfont-size: 20px;\n\tfont-weight: normal;\n}\n\n/* Meta box same like PDF */\n.adsd-paper-v2 .meta-table {\n\twidth: 100%;\n\tborder-collapse: collapse;\n\tmargin-top: -8px;\n\tmargin-bottom: 18px;\n\tfont-size: 16px;\n}\n\n.adsd-paper-v2 .meta-table td {\n\tborder: 1px solid #999 !important;\n\theight: 21px;\n\tpadding: 1px 7px;\n\tvertical-align: middle;\n}\n\n.adsd-paper-v2 .meta-left {\n\twidth: 50%;\n}\n\n.adsd-paper-v2 .meta-right {\n\twidth: 50%;\n}\n\n/* Questions - no table border */\n.adsd-paper-v2 .question-row {\n\tdisplay: grid;\n\tgrid-template-columns: 48px 48px 42px 1fr;\n\talign-items: start;\n\tmargin-bottom: 19px;\n\tpage-break-inside: avoid;\n\tbreak-inside: avoid;\n}\n\n.adsd-paper-v2 .yn {\n\ttext-align: center;\n\tfont-size: 14px;\n}\n\n.adsd-paper-v2 .qno {\n\ttext-align: right;\n\tpadding-right: 7px;\n\tfont-size: 16px;\n}\n\n.adsd-paper-v2 .qtext {\n\tfont-size: 16px;\n\tline-height: 1.12;\n}\n\n/* Force remove any ERPNext/global table borders */\n.adsd-paper-v2 table,\n.adsd-paper-v2 tr,\n.adsd-paper-v2 td,\n.adsd-paper-v2 th {\n\tbackground: transparent !important;\n}\n\n.adsd-paper-v2 .questions-area,\n.adsd-paper-v2 .questions-area * {\n\tborder: none !important;\n}\n</style>\n\n<div class=\"adsd-paper-v2\">\n\n\t<div class=\"top-area\">\n\t\t<div class=\"logo-area\">\n\t\t\t<img src=\"/files/adnoc.png\">\n\t\t\t<div class=\"logo-text\">ADNOC</div>\n\t\t</div>\n\n\t\t<div class=\"title-area\">\n\t\t\t<div class=\"main-org\">ADNOC</div>\n\t\t\t<div class=\"course-title\">Course Title: {{ doc.course_title or \"ADSD\" }}</div>\n\t\t\t<div class=\"test-title\">{{ doc.test_name or \"Theory Test A ( Pre - Test )\" }}</div>\n\t\t</div>\n\t</div>\n\n<br/>\n\n<br/>\n\n<br/>\n\t<table class=\"meta-table\">\n\t\t<tr>\n\t\t\t<td class=\"meta-left\">\n\t\t\t\tDate: {{ frappe.utils.formatdate(doc.test_date, \"dd-MM-yyyy\") if doc.test_date else \"\" }}\n\t\t\t</td>\n\t\t\t<td class=\"meta-right\">\n\t\t\t\tTotal Marks : {{ doc.total_marks or \"20\" }}\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"meta-left\">\n\t\t\t\tName: {{ doc.candidate_name or \"\" }}\n\t\t\t</td>\n\t\t\t<td class=\"meta-right\"></td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td class=\"meta-left\">\n\t\t\t\tTel # {{ doc.telephone or \"\" }}\n\t\t\t</td>\n\t\t\t<td class=\"meta-right\">\n\t\t\t\tCo # No {{ doc.company_no or \"\" }}\n\t\t\t</td>\n\t\t</tr>\n\t</table>\n\n\t<div class=\"questions-area\">\n\t\t{% for row in doc.questions %}\n\t\t<div class=\"question-row\">\n\t\t\t<div class=\"yn\">Yes</div>\n\t\t\t<div class=\"yn\">No</div>\n\t\t\t<div class=\"qno\">{{ row.sr_no or loop.index }}.</div>\n\t\t\t<div class=\"qtext\">{{ row.question }}</div>\n\t\t</div>\n\t\t{% endfor %}\n\t</div>\n\n</div>",
