 "css": ".adsd-form { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; color: #000; }\n.adsd-header { display: flex; align-items: flex-start; margin-bottom: 10px; }\n.adsd-logo { font-weight: 700; font-size: 18pt; color: #004b87; min-width: 100px; }\n.adsd-titles { flex: 1; text-align: center; }\n.adsd-org { font-size: 16pt; font-weight: 700; letter-spacing: 2px; }\n.adsd-test-name { font-weight: 700; margin-top: 4px; }\n.adsd-meta { width: 100%; border-collapse: collapse; margin-bottom: 12px; }\n.adsd-meta td { border: 1px solid #000; padding: 4px 6px; }\n.adsd-meta .label { width: 12%; font-weight: 700; }\n.adsd-meta .value { width: 38%; }\n.adsd-questions { width: 100%; border-collapse: collapse; }\n.adsd-questions td { border: 1px solid #000; padding: 4px 6px; vertical-align: top; }\n.adsd-questions .yn { width: 8%; text-align: center; white-space: nowrap; }\n.adsd-questions .qno { width: 5%; text-align: center; }\n.adsd-questions .qtext { width: 79%; }\n.adsd-result { margin-top: 12px; }",
