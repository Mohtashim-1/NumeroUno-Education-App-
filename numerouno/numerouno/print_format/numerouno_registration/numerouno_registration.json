 "html": "<style>\n    @page {\n        size: A4;\n        margin: 12mm 10mm 12mm 10mm;\n    }\n\n    html, body {\n        width: 210mm;\n        min-height: 297mm;\n        margin: 0;\n        padding: 0;\n        font-family: Arial, Helvetica, sans-serif;\n        color: #222222;\n        font-size: 12px;\n        line-height: 1.35;\n    }\n\n    .print-format {\n        width: 100%;\n        max-width: 190mm;\n        margin: 0 auto;\n        padding: 0;\n        font-family: Arial, Helvetica, sans-serif;\n        color: #222222;\n        font-size: 12px;\n        line-height: 1.35;\n        box-sizing: border-box;\n    }\n\n    .letter-head {\n        width: 100%;\n        margin-bottom: 6px;\n    }\n\n    .main-title {\n        text-align: center;\n        font-size: 18px;\n        font-weight: bold;\n        color: #0d47a1;\n        margin: 4px 0 4px 0;\n    }\n\n    .blue-line {\n        border-top: 2px solid #1e5eff;\n        margin: 8px 0 14px 0;\n    }\n\n    .section-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 10px;\n        table-layout: fixed;\n    }\n\n    .section-heading {\n        background-color: #dfe8f5;\n        color: #143d8d;\n        font-weight: bold;\n        font-size: 12px;\n        text-transform: uppercase;\n        padding: 8px 10px;\n        border: 1px solid #c9d3e3;\n    }\n\n    .label-cell {\n        width: 34%;\n        background-color: #f7f7f7;\n        font-weight: bold;\n        padding: 6px 8px;\n        border: 1px solid #d9d9d9;\n        vertical-align: top;\n        word-wrap: break-word;\n    }\n\n    .value-cell {\n        width: 66%;\n        padding: 6px 8px;\n        border: 1px solid #d9d9d9;\n        vertical-align: top;\n        word-wrap: break-word;\n    }\n\n    .terms-section {\n        margin-top: 10px;\n        border-top: 2px solid #1e5eff;\n        padding-top: 8px;\n        page-break-inside: avoid;\n    }\n\n    .terms-title {\n        font-weight: bold;\n        font-size: 13px;\n        color: #0d47a1;\n        margin-bottom: 6px;\n    }\n\n    .terms-list {\n        font-size: 11px;\n        line-height: 1.4;\n        color: #333333;\n        padding-left: 18px;\n        margin: 0;\n    }\n\n    .terms-list li {\n        margin-bottom: 4px;\n        text-align: justify;\n    }\n\n    .footer-sign-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 20px;\n        page-break-inside: avoid;\n    }\n\n    .footer-sign-cell-left,\n    .footer-sign-cell-right {\n        width: 50%;\n        vertical-align: bottom;\n    }\n\n    .footer-sign-cell-left {\n        text-align: left;\n    }\n\n    .footer-sign-cell-right {\n        text-align: right;\n    }\n\n    .signature-img {\n        display: block;\n        max-height: 38px;\n        max-width: 140px;\n        margin-bottom: 6px;\n    }\n\n    .sign-line {\n        display: inline-block;\n        width: 160px;\n        border-top: 1px solid #222222;\n        padding-top: 4px;\n        font-weight: bold;\n        font-size: 11px;\n    }\n\n    .avoid-break {\n        page-break-inside: avoid;\n    }\n\n    table, tr, td {\n        page-break-inside: avoid;\n    }\n</style>\n\n<div class=\"print-format\">\n\n    {% if letter_head %}\n        <div class=\"letter-head\">\n            {{ letter_head }}\n        </div>\n    {% endif %}\n\n    <div class=\"main-title\">Registration Form</div>\n    <div class=\"blue-line\"></div>\n\n    <table class=\"section-table avoid-break\">\n        <tr>\n            <td colspan=\"2\" class=\"section-heading\">Candidate Details</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Full Name</td>\n            <td class=\"value-cell\">{{ doc.full_name or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Passport / Emirates ID</td>\n            <td class=\"value-cell\">{{ doc.passport_emirates_id or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Series</td>\n            <td class=\"value-cell\">{{ doc.naming_series or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Nationality</td>\n            <td class=\"value-cell\">{{ doc.nationality or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Date of Birth</td>\n            <td class=\"value-cell\">\n                {{ frappe.utils.formatdate(doc.date_of_birth, \"dd-MM-yyyy\") if doc.date_of_birth else \"\" }}\n            </td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Contact Number</td>\n            <td class=\"value-cell\">{{ doc.contact_number or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Email</td>\n            <td class=\"value-cell\">{{ doc.email or \"\" }}</td>\n        </tr>\n    </table>\n\n    <table class=\"section-table avoid-break\">\n        <tr>\n            <td colspan=\"2\" class=\"section-heading\">Company Details</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Company Name</td>\n            <td class=\"value-cell\">{{ doc.company_name or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Contact Person</td>\n            <td class=\"value-cell\">{{ doc.contact_person or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Contact Number</td>\n            <td class=\"value-cell\">{{ doc.company_contact_number or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Company Address</td>\n            <td class=\"value-cell\">{{ doc.company_address or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Email</td>\n            <td class=\"value-cell\">{{ doc.company_email or \"\" }}</td>\n        </tr>\n    </table>\n\n    <table class=\"section-table avoid-break\">\n        <tr>\n            <td colspan=\"2\" class=\"section-heading\">Course Details</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Course</td>\n            <td class=\"value-cell\">{{ doc.course or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Location</td>\n            <td class=\"value-cell\">{{ doc.location or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Duration</td>\n            <td class=\"value-cell\">{{ doc.duration or \"\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"label-cell\">Preferred Date</td>\n            <td class=\"value-cell\">\n                {{ frappe.utils.formatdate(doc.preferred_date, \"dd-MM-yyyy\") if doc.preferred_date else \"\" }}\n            </td>\n        </tr>\n    </table>\n\n    <div class=\"terms-section avoid-break\">\n        <div class=\"terms-title\">Terms & Conditions</div>\n        <ol class=\"terms-list\">\n            <li><b>Registrations:</b> Participants may register by e-mail with payment by cash, bank transfer or cheque.</li>\n            <li><b>Payment Receipts:</b> All registered delegates will receive an acknowledgement of registration together with confirmation of payment.</li>\n            <li><b>Cancellations:</b> Cancellations by delegates must be made in writing and received one week before the seminar. No refunds will be made or invoices cancelled after this date and the full registration fee will be payable. Substitutions may be made at any time.</li>\n            <li><b>Cancellation by Organizers:</b> We reserve the right to cancel the event if it is under subscribed or for any other reason. In such cases, one-week notice will be given and the fee will be refunded in full. We are not liable for any pre-booked travel or accommodation costs.</li>\n            <li><b>Joining Instructions:</b> Two days before the training, participants will receive an email with details regarding venue, location, agenda, certification, and other formalities.</li>\n            <li><b>No Show Policy:</b> If the delegate fails to attend the training, the deposited amount will not be refunded.</li>\n        </ol>\n    </div>\n\n    <table class=\"footer-sign-table\">\n        <tr>\n            <td class=\"footer-sign-cell-left\">\n                {% if doc.signature %}\n                    <img src=\"{{ doc.signature }}\" class=\"signature-img\">\n                {% endif %}\n                <span class=\"sign-line\">Candidate Signature</span>\n            </td>\n            <td class=\"footer-sign-cell-right\">\n                <!--<span class=\"sign-line\">Authorized Signature</span>-->\n            </td>\n        </tr>\n    </table>\n\n</div>",
