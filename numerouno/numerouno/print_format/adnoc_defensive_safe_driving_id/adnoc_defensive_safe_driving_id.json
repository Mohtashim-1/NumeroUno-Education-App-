 "html": "<!-- ADNOC Driving ID - Front + Back on One Page -->\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap');\n\n  @page {\n    size: A4 portrait;\n    margin: 8mm;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: Arial, sans-serif;\n  }\n\n  .adnoc-sheet {\n    width: 100%;\n    page-break-inside: avoid;\n    break-inside: avoid;\n  }\n\n  .adnoc-front,\n  .adnoc-back {\n    width: 380px;\n    height: 240px;\n    margin: 0 auto 12px auto;\n    position: relative;\n  }\n\n  .adnoc-front-img,\n  .adnoc-back-img {\n    display: block;\n    width: 380px;\n    height: auto;\n  }\n\n  .adnoc-fields-overlay {\n    position: absolute;\n    top: 76px;\n    left: 0;\n    width: 100%;\n    padding: 0 10px;\n    box-sizing: border-box;\n  }\n\n  .adnoc-fields {\n    width: 100%;\n    border-collapse: collapse;\n  }\n\n  .adnoc-fields tr td {\n    padding: 2.5px 3px;\n    vertical-align: middle;\n    line-height: 1.2;\n  }\n\n  .adnoc-lbl {\n    font-size: 7px;\n    font-weight: 700;\n    color: #003087;\n    margin-right: 2px;\n  }\n\n  .adnoc-lbl-ar {\n    font-size: 7px;\n    font-weight: 700;\n    color: #003087;\n    margin-left: 4px;\n    font-family: 'Cairo', Arial, sans-serif;\n  }\n\n  .adnoc-val {\n    font-size: 6.5px;\n    color: #333;\n  }\n\n  .adnoc-val-ar {\n    font-size: 6.5px;\n    color: #333;\n    font-family: 'Cairo', Arial, sans-serif;\n  }\n\n  .adnoc-qr-overlay {\n    position: absolute;\n    top: 170px;\n    left: 10px;\n  }\n\n  .adnoc-qr-box {\n    width: 44px;\n    height: 44px;\n    background: #fff;\n    border: 2px solid #003087;\n    border-radius: 3px;\n    overflow: hidden;\n    padding: 1px;\n    box-sizing: border-box;\n  }\n\n  .adnoc-qr-txt {\n    font-size: 6px;\n    color: #000;\n    display: block;\n    margin-top: 2px;\n    text-align: center;\n  }\n\n  .adnoc-company-header {\n    position: absolute;\n    top: 48px;\n    left: 0;\n    width: 100%;\n    text-align: center;\n    font-size: 10px;\n    font-weight: 700;\n    color: #003087;\n    letter-spacing: 0.5px;\n  }\n  \n.adnoc-phone-overlay {\n  position: absolute;\n  top: 160px;        /* moved down to the white oval area */\n  right: 50px;       /* pulled left to center in the oval */\n  width: 80px;\n  text-align: center;\n  z-index: 10;       /* make sure it's on top */\n}\n\n.adnoc-phone-lbl {\n  font-size: 6.5px;\n  font-weight: 700;\n  color: #003087;\n  display: block;\n  margin-bottom: 2px;\n}\n\n.adnoc-phone-val {\n  font-size: 7.5px;\n  font-weight: 700;\n  color: #000;\n  display: block;\n  word-break: break-all;\n}\n\n  @media print {\n    .adnoc-sheet,\n    .adnoc-front,\n    .adnoc-back {\n      page-break-inside: avoid !important;\n      break-inside: avoid !important;\n    }\n  }\n</style>\n\n{% set student = frappe.get_doc(\"Student\", doc.student) %}\n{% set base_url = \"https://erpnext.nutc.cloud\" %}\n{% set verify_url = base_url ~ \"/certificate-verification?cert=\" ~ doc.name %}\n\n{% set emp_id = (student.employee_id or '') %}\n{% set issue = (doc.issue_date or doc.posting_date or '') %}\n{% set expiry = (doc.expiry_date or '') %}\n{% set vt = (doc.vehicle_type or '') %}\n\n<div class=\"adnoc-sheet\">\n\n  <!-- FRONT -->\n  <div class=\"adnoc-front\">\n    <img src=\"/files/ADNOC Defensive Safe Driving ID (4).png\" class=\"adnoc-front-img\"/>\n\n<div class=\"adnoc-phone-overlay\">\n  <img src=\"{{ student.custom_photo or '' }}\" \n       width=\"75\" \n       height=\"75\" \n       style=\"border-radius: 50%; object-fit: cover; border: 2px solid #003087; display: block;\"/>\n</div>\n\n\n   <div class=\"adnoc-fields-overlay\">\n      <table class=\"adnoc-fields\">\n        <tr>\n          <td>\n            <span class=\"adnoc-lbl\">Name:</span>\n            <span class=\"adnoc-val\">{{ (student.first_name or '')[:25] }}</span>\n            &nbsp;&nbsp;\n            <span class=\"adnoc-val-ar\">{{ student.custom_full_name_arabic or '' }}</span>\n            <span class=\"adnoc-lbl-ar\">:\u0627\u0644\u0627\u0633\u0645</span>\n          </td>\n        </tr>\n        <tr>\n          <td>\n            <span class=\"adnoc-lbl\">Employee ID:</span>\n            <span class=\"adnoc-val\">{{ student.employee_id or '' }}</span>\n            &nbsp;&nbsp;\n\n            {% set emp_id = (student.employee_id or '') %}\n            <span class=\"adnoc-val-ar\">\n              {{ emp_id\n                | replace('0','\u0660')\n                | replace('1','\u0661')\n                | replace('2','\u0662')\n                | replace('3','\u0663')\n                | replace('4','\u0664')\n                | replace('5','\u0665')\n                | replace('6','\u0666')\n                | replace('7','\u0667')\n                | replace('8','\u0668')\n                | replace('9','\u0669')\n              }}\n            </span>\n            <span class=\"adnoc-lbl-ar\">:\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0648\u0638\u064a\u0641\u064a</span>\n          </td>\n        </tr>\n        <tr>\n          <td>\n            <span class=\"adnoc-lbl\">Company:</span>\n            <span class=\"adnoc-val adnoc-company\">\n              {{ (student.customer_name or '')[:30] }}{% if (student.customer_name or '')|length > 55 %}...{% endif %}\n            </span>\n            &nbsp;&nbsp;\n            <span class=\"adnoc-val-ar\">{{ student.custom_customer_name_arabic or '' }}</span>\n            <span class=\"adnoc-lbl-ar\">:\u0627\u0644\u0634\u0631\u0643\u0629</span>\n          </td>\n        </tr>\n\n        {% set vt = doc.vehicle_type or '' %}\n        <tr>\n          <td>\n            <span class=\"adnoc-lbl\">Vehicle Type:</span>\n            <span class=\"adnoc-val\">{{ vt }}</span>\n            &nbsp;&nbsp;\n\n            <span class=\"adnoc-val-ar\">\n              {% if vt == \"HGV\" %}\n                \u0645\u0631\u0643\u0628\u0629 \u062b\u0642\u064a\u0644\u0629\n              {% elif vt == \"LMV\" %}\n                \u0645\u0631\u0643\u0628\u0629 \u062e\u0641\u064a\u0641\u0629\n              {% elif vt == \"HVB\" %}\n                \u0645\u0631\u0643\u0628\u0629 \u062b\u0642\u064a\u0644\u0629 (\u062d\u0627\u0641\u0644\u0629)\n              {% elif vt == \"HV\" %}\n                \u0645\u0631\u0643\u0628\u0629 \u062b\u0642\u064a\u0644\u0629\n              {% else %}\n                {{ vt }}\n              {% endif %}\n            </span>\n\n            <span class=\"adnoc-lbl-ar\">:\u0646\u0648\u0639 \u0627\u0644\u0645\u0631\u0643\u0628\u0629</span>\n          </td>\n        </tr>\n\n        {% set issue = (doc.issue_date or '') %}\n        <tr>\n          <td>\n            <span class=\"adnoc-lbl\">Issue Date:</span>\n            <span class=\"adnoc-val\">{{ issue }}</span>\n            &nbsp;&nbsp;\n\n            <span class=\"adnoc-val-ar\">\n              {{ issue\n                | replace('0','\u0660')\n                | replace('1','\u0661')\n                | replace('2','\u0662')\n                | replace('3','\u0663')\n                | replace('4','\u0664')\n                | replace('5','\u0665')\n                | replace('6','\u0666')\n                | replace('7','\u0667')\n                | replace('8','\u0668')\n                | replace('9','\u0669')\n              }}\n            </span>\n\n            <span class=\"adnoc-lbl-ar\">:\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0625\u0635\u062f\u0627\u0631</span>\n          </td>\n        </tr>\n\n        {% set expiry = (doc.expiry_date or '') %}\n        <tr>\n          <td>\n            <span class=\"adnoc-lbl\">Expiry Date:</span>\n            <span class=\"adnoc-val\">{{ expiry }}</span>\n            &nbsp;&nbsp;\n\n            <span class=\"adnoc-val-ar\">\n              {{ expiry\n                | replace('0','\u0660')\n                | replace('1','\u0661')\n                | replace('2','\u0662')\n                | replace('3','\u0663')\n                | replace('4','\u0664')\n                | replace('5','\u0665')\n                | replace('6','\u0666')\n                | replace('7','\u0667')\n                | replace('8','\u0668')\n                | replace('9','\u0669')\n              }}\n            </span>\n\n            <span class=\"adnoc-lbl-ar\">:\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621</span>\n          </td>\n        </tr>\n      </table>\n    </div>\n\n    <div class=\"adnoc-qr-overlay\">\n      <div class=\"adnoc-qr-box\">\n        <img src=\"{{ verify_url | qr_code }}\" width=\"40\" height=\"40\" style=\"display:block;\"/>\n      </div>\n      \n    </div>\n  </div>\n\n  <!-- BACK -->\n  <div class=\"adnoc-back\">\n    <img src=\"/files/ADNOC Defensive Safe Driving ID.png\" class=\"adnoc-back-img\"/>\n  </div>\n\n</div>",
